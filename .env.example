# Copy to .env and fill in. Same Supabase project as callting/, but the
# "voting" schema (not "public") so this stays fully isolated from
# callting's tables. Get the base connection string from Supabase
# dashboard -> Connect -> ORMs -> Prisma, then append &schema=voting
# (DATABASE_URL) or ?schema=voting (DIRECT_URL).
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=voting"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?schema=voting"
